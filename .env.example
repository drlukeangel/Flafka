# Flafka — Environment Variables
# Copy this file to .env and fill in your Confluent Cloud credentials.
#
#   cp .env.example .env
#

# ── Confluent Cloud Organization ──────────────────────────────────────
VITE_ORG_ID=org-xxxxx
VITE_ENV_ID=env-xxxxx
VITE_COMPUTE_POOL_ID=lfcp-xxxxx

# ── Flink SQL API (required) ─────────────────────────────────────────
# Create a Flink API key in Confluent Cloud → Environments → your env → API keys
VITE_FLINK_API_KEY=your-flink-api-key
VITE_FLINK_API_SECRET=your-flink-api-secret

# ── Cloud Region ─────────────────────────────────────────────────────
VITE_CLOUD_PROVIDER=aws
VITE_CLOUD_REGION=us-east-1

# ── API URL Overrides (optional — for private link / VPC peering) ────
# These override the default public Confluent Cloud URLs
# VITE_FLINK_API_URL=https://your-private-flink-endpoint.example.com
# VITE_CONFLUENT_API_URL=https://your-private-api-endpoint.example.com
# VITE_TELEMETRY_API_URL=https://your-private-telemetry-endpoint.example.com

# ── Flink Catalog & Database (defaults shown) ────────────────────────
VITE_FLINK_CATALOG=default
VITE_FLINK_DATABASE=public

# ── Metrics / Telemetry API ──────────────────────────────────────────
# Cloud API key for compute pool metrics, artifact management, and E2E test cleanup
VITE_METRICS_KEY=your-cloud-api-key
VITE_METRICS_SECRET=your-cloud-api-secret

# ── Schema Registry ──────────────────────────────────────────────────
# Required for schema browser and topic detail views
VITE_SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-east-1.aws.confluent.cloud
VITE_SCHEMA_REGISTRY_KEY=your-sr-api-key
VITE_SCHEMA_REGISTRY_SECRET=your-sr-api-secret

# ── Kafka REST Proxy ─────────────────────────────────────────────────
# Required for stream preview (consuming topic messages)
VITE_KAFKA_CLUSTER_ID=lkc-xxxxx
VITE_KAFKA_REST_ENDPOINT=https://pkc-xxxxx.us-east-1.aws.confluent.cloud:443
VITE_KAFKA_API_KEY=your-kafka-api-key
VITE_KAFKA_API_SECRET=your-kafka-api-secret

# ── ksqlDB (optional — set ENABLED=true to show engine toggle) ──────
VITE_KSQL_ENABLED=false
VITE_KSQL_ENDPOINT=https://pksqlc-xxxxx.us-east-1.aws.confluent.cloud:443
VITE_KSQL_API_KEY=
VITE_KSQL_API_SECRET=

# ── Optional ─────────────────────────────────────────────────────────
VITE_UNIQUE_ID=your-unique-id

# ── Environment Mode ────────────────────────────────────────────────
# Controls default values for topic creation and other dev-friendly settings.
# "dev" = low partitions (1), short retention (1 hour) for fast iteration
# "production" = standard defaults (6 partitions, broker-default retention)
# VITE_ENVIRONMENT=dev

# ── Admin Override ──────────────────────────────────────────────────
# Enables "Show All" toggle in the nav rail to bypass unique_id filtering
# and see all resources (topics, schemas, statements, jobs, artifacts).
# Also grants manage permissions (delete topics, cancel jobs) on any resource.
# Set to FLAFKA to enable admin mode.
# VITE_ADMIN_SECRET=FLAFKA
